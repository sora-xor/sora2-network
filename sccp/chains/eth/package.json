{
  "name": "sccp-eth",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "compile": "bash ./scripts/compile.sh",
    "compile:deploy": "node ./scripts/compile_deploy_contracts.mjs",
    "test": "bash ./scripts/run_hardhat.sh test",
    "extract-burn-proof-inputs": "node ./scripts/extract_burn_proof_inputs.mjs",
    "encode-governance-payload": "node ./scripts/encode_governance_payload.mjs",
    "deploy:mainnet": "python3 ./scripts/deploy_mainnet.py",
    "test:deploy-scripts": "bash ./scripts/test_deploy_scripts.sh",
    "check:repo-hygiene": "bash ./scripts/check_repo_hygiene.sh",
    "test:ci-formal": "bash ./scripts/test_ci_formal.sh",
    "test:formal-assisted": "node ./scripts/formal_assisted.mjs",
    "test:formal-assisted:ci": "bash ./scripts/test_formal_assisted.sh",
    "test:fuzz:fastcheck": "bash ./scripts/run_hardhat.sh test test/fuzz/*.fastcheck.test.js",
    "test:fuzz:foundry": "bash ./scripts/fuzz_foundry.sh",
    "test:fuzz:echidna": "bash ./scripts/fuzz_echidna.sh",
    "test:fuzz": "npm run test:fuzz:fastcheck && npm run test:fuzz:foundry && npm run test:fuzz:echidna",
    "test:fuzz:nightly": "bash ./scripts/test_fuzz_nightly.sh",
    "test:ci-fuzz": "bash ./scripts/test_ci_fuzz.sh",
    "test:ci-all": "bash ./scripts/test_ci_all.sh"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.4",
    "@nomicfoundation/hardhat-mocha": "^3.0.9",
    "chai": "^5.3.3",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.8",
    "mocha": "^11.0.0",
    "fast-check": "^3.23.2"
  },
  "overrides": {
    "diff": "8.0.3",
    "minimatch": "9.0.7",
    "serialize-javascript": "7.0.4"
  }
}
