{
  "defaults": {
    "maxMinutes": 120,
    "perCommandTimeoutSeconds": 1800,
    "includeNegative": true,
    "matrix": "sora-core-pairs",
    "commandCache": true
  },
  "matrixPresets": {
    "sora-pairs": "sora-pairs",
    "sora-core-pairs": "sora-core-pairs",
    "full": "full"
  },
  "modes": {
    "pr": {
      "defaults": {
        "maxMinutes": 45
      },
      "commands": {
        "preflight": {
          "enabled": false
        }
      },
      "matrix": "sora-core-pairs"
    },
    "nightly": {
      "defaults": {
        "maxMinutes": 240,
        "commandCache": false
      },
      "commands": {
        "preflight": {
          "enabled": false
        }
      },
      "matrix": "full"
    },
    "release": {
      "defaults": {
        "maxMinutes": 120,
        "commandCache": false
      },
      "commands": {
        "preflight": {
          "enabled": false
        }
      },
      "matrix": "full"
    }
  },
  "paths": {
    "sora2Network": "${repoRoot}",
    "iroha": "${repoRoot}/siblings/iroha",
    "sccpEth": "${repoRoot}/sccp/chains/eth",
    "sccpBsc": "${repoRoot}/sccp/chains/bsc",
    "sccpSol": "${repoRoot}/sccp/chains/sol",
    "sccpTon": "${repoRoot}/sccp/chains/ton",
    "sccpTron": "${repoRoot}/sccp/chains/tron",
    "sccpSoraKusama": "${repoRoot}/siblings/sora2-parachain",
    "sccpSoraPolkadot": "${repoRoot}/siblings/sora2-parachain"
  },
  "commands": {
    "preflight": {
      "enabled": false,
      "cmd": "misc/sccp/run_all_tests.sh",
      "cwd": "${sora2Network}"
    },
    "sora": {
      "burn": "cargo test -p sccp",
      "mint_verify": "cargo test -p framenode-runtime sccp_ -- --nocapture",
      "negative_verify": "cargo test -p sccp -- --nocapture"
    },
    "hub": {
      "publish_bundle": "if [ -n \"$SCCP_MESSAGE_ID\" ] && [ -n \"$SCCP_NEXUS_TORII_URL\" ]; then node ${sora2Network}/misc/sccp-e2e/src/fetch_nexus_bundle.js --torii-url \"$SCCP_NEXUS_TORII_URL\" --output-dir \"$SCCP_SCENARIO_DIR\"; elif [ -n \"$SCCP_MESSAGE_ID\" ]; then node ${sora2Network}/misc/sccp-e2e/src/fetch_nexus_bundle.js --torii-url http://127.0.0.1:8080 --output-dir \"$SCCP_SCENARIO_DIR\"; else cargo test -p iroha_torii --lib sccp_ -- --nocapture; fi"
    },
    "domains": {
      "eth": {
        "burn": "npm test",
        "mint_verify": "npm test",
        "negative_verify": "npm test"
      },
      "bsc": {
        "burn": "npm test",
        "mint_verify": "npm test",
        "negative_verify": "npm test"
      },
      "tron": {
        "burn": "npm test",
        "mint_verify": "npm test",
        "negative_verify": "npm test"
      },
      "sol": {
        "burn": "cargo test",
        "mint_verify": "cargo test",
        "negative_verify": "cargo test"
      },
      "ton": {
        "burn": "npm test",
        "mint_verify": "npm test",
        "negative_verify": "npm test"
      },
      "sora_kusama": {
        "burn": "cargo test -p sccp-link",
        "mint_verify": "cargo test -p sccp-link",
        "negative_verify": "cargo test -p sccp-link"
      },
      "sora_polkadot": {
        "burn": "cargo test -p sccp-link",
        "mint_verify": "cargo test -p sccp-link",
        "negative_verify": "cargo test -p sccp-link"
      }
    }
  }
}
