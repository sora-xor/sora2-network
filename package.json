{
  "name": "sora2-network-sccp-workspace",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "sccp:help": "bash ./sccp/tools/sccp-proof.sh --help",
    "sccp:test:eth": "pnpm --dir sccp/chains/eth test",
    "sccp:test:bsc": "pnpm --dir sccp/chains/bsc test",
    "sccp:test:tron": "pnpm --dir sccp/chains/tron test",
    "sccp:test:ton": "pnpm --dir sccp/chains/ton test",
    "sccp:test:sol:js": "pnpm --dir sccp/chains/sol/js/solana-finalized-burn-proof test"
  }
}
